<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!--
        Matches Context.getExternalFilesDir(Environment.DIRECTORY_DOCUMENTS)
        which is where AttendancePdfGenerator writes the PDF file.
    -->
    <external-files-path
        name="attendance_pdfs"
        path="Documents/" />

    <!--
        Fallback: internal files dir (used if external storage is unavailable).
    -->
    <files-path
        name="attendance_pdfs_internal"
        path="." />
</paths>